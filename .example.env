# A .env file should exist at the root level of this generator environment and include these values

#if MODEL_TYPE is local, you only need to set LOCAL_MODEL_NAME
#if MODEL_TYPE is azure_openai then set all AZURE_OPENAI settings
#if MODEL_TYPE is local_openai then set LOCAL_OPENAI settings for any OpenAI-compatible API
MODEL_TYPE=local
LOCAL_MODEL_NAME=phi3.5

# Local OpenAI-compatible API (LM Studio, vLLM, text-generation-webui, etc.)
LOCAL_OPENAI_ENDPOINT=http://localhost:1234/v1
LOCAL_OPENAI_API_KEY=no-key-required
LOCAL_OPENAI_TEXT_MODEL=your-text-model
LOCAL_OPENAI_IMAGE_MODEL=your-image-model
LOCAL_OPENAI_IMAGE_ENDPOINT=
LOCAL_OPENAI_VISION_MODEL=your-vision-model
LOCAL_OPENAI_VISION_ENDPOINT=

AZURE_OPENAI_TEXT_ENDPOINT_KEY=youropenapikey
AZURE_OPENAI_TEXT_ENDPOINT=https://yourazureopenurl.openai.azure.com/
AZURE_OPENAI_TEXT_DEPLOYMENT_NAME=yourdeploymentname
AZURE_OPENAI_TEXT_API_VERSION=2024-02-15-preview

AZURE_OPENAI_IMAGE_ENDPOINT_KEY=
AZURE_OPENAI_IMAGE_ENDPOINT=
AZURE_OPENAI_IMAGE_DEPLOYMENT_NAME=
AZURE_OPENAI_IMAGE_API_VERSION=

AZURE_OPENAI_VISION_ENDPOINT_KEY=
AZURE_OPENAI_VISION_ENDPOINT=
AZURE_OPENAI_VISION_DEPLOYMENT_NAME=
AZURE_OPENAI_VISION_API_VERSION=

DB_SERVER=localhost
DB_NAME=BattleCabbageVideo
DB_USER=sa
DB_PASSWORD=yourpassword
DB_DRIVER=ODBC Driver 18 for SQL Server

# Comma-separated list of valid API keys for write operations (e.g. poster upload)
API_KEYS=your-api-key-here